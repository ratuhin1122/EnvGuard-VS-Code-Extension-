{
  "name": "envguardsmartmanager",
  "displayName": "EnvGuard-Environment Smart Manager",
  "description": "Framework-agnostic environment file manager. Discover, parse, compare, and audit .env, .properties, and YAML config files across any project.",
  "version": "2.0.0",
  "publisher": "Tuhin1122",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1c5f6e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ratuhin1122/EnvGuard-VS-Code-Extension-.git"
  },
  "bugs": {
    "url": "https://github.com/ratuhin1122/EnvGuard-VS-Code-Extension-/issues"
  },
  "homepage": "https://github.com/ratuhin1122/EnvGuard-VS-Code-Extension-#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "env",
    "dotenv",
    "environment",
    "configuration",
    "properties",
    "yaml"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "envguard",
          "title": "EnvGuard",
          "icon": "resources/envguard.svg"
        }
      ]
    },
    "views": {
      "envguard": [
        {
          "id": "envguard.environmentFiles",
          "name": "Environment Files"
        },
        {
          "id": "envguard.missingKeys",
          "name": "Missing Keys"
        },
        {
          "id": "envguard.comparisonResults",
          "name": "Comparison Results"
        }
      ]
    },
    "commands": [
      {
        "command": "envguard.scan",
        "title": "EnvGuard: Scan Environment Files",
        "icon": "$(search)"
      },
      {
        "command": "envguard.compare",
        "title": "EnvGuard: Compare Files",
        "icon": "$(diff)"
      },
      {
        "command": "envguard.refresh",
        "title": "EnvGuard: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "envguard.exportReport",
        "title": "EnvGuard: Export Report",
        "icon": "$(save)"
      },
      {
        "command": "envguard.installPrePushHook",
        "title": "EnvGuard: Install Pre-Push Hook",
        "icon": "$(shield)"
      },
      {
        "command": "envguard.uninstallPrePushHook",
        "title": "EnvGuard: Uninstall Pre-Push Hook"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "envguard.refresh",
          "when": "view == envguard.environmentFiles",
          "group": "navigation"
        },
        {
          "command": "envguard.compare",
          "when": "view == envguard.comparisonResults",
          "group": "navigation"
        },
        {
          "command": "envguard.exportReport",
          "when": "view == envguard.missingKeys",
          "group": "navigation"
        },
        {
          "command": "envguard.installPrePushHook",
          "when": "view == envguard.environmentFiles",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "EnvGuard",
      "properties": {
        "envguard.gitHook.mode": {
          "type": "string",
          "enum": [
            "warn",
            "strict"
          ],
          "enumDescriptions": [
            "Print validation warnings but always allow the push to continue.",
            "Block the push (non-zero exit) when validation finds problems."
          ],
          "default": "warn",
          "description": "Behavior of the EnvGuard pre-push hook when environment validation finds issues. Changing this updates an already-installed hook automatically."
        },
        "envguard.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline diagnostics (squiggles and Problems-panel entries) for .env files: missing and empty variables required by .env.example."
        },
        "envguard.diagnostics.severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "hint"
          ],
          "default": "warning",
          "description": "Severity used for EnvGuard inline diagnostics."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
